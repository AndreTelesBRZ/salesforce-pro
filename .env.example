# Front-end (Vite) public variables must be prefixed with VITE_
# Used by services/geminiService.ts
# Se usar Gemini no backend, configure GEMINI_API_KEY (não é necessário VITE_ no frontend)
GEMINI_API_KEY=
# Backend único multi-tenant.
# O frontend resolve a loja pelo domínio acessado:
# - *.edsondosparafusos.app.br -> Loja 01 -> VITE_APP_INTEGRATION_TOKEN_EDSON
# - *.llfix.app.br -> Loja 03 -> VITE_APP_INTEGRATION_TOKEN_LLFIX
# Qualquer outro domínio deve falhar com "domínio não configurado".
VITE_BACKEND_URL=https://apiforce.edsondosparafusos.app.br
VITE_API_USERNAME=apiadmin
VITE_API_PASSWORD=TroqueEstaSenha!
# Tokens fixos por tenant usados automaticamente pelo hostname
VITE_APP_INTEGRATION_TOKEN_EDSON=
VITE_APP_INTEGRATION_TOKEN_LLFIX=
# VITE_APP_INTEGRATION_TOKEN foi descontinuado e não deve mais ser usado.

# Backend secrets (server.js)
SECRET_KEY=
MASTER_KEY=
APP_INTEGRATION_TOKEN=
APP_INTEGRATION_TOKEN_EDSON=
APP_INTEGRATION_TOKEN_LLFIX=
GOOGLE_CLIENT_ID=
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL="SalesForce <no-reply@salesforce.pro>"
# DATABASE_URL=postgres://user:pass@host:5432/db
# SQLite path (inside container uses /data)
DB_PATH=./database.sqlite
